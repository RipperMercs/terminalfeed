# Cloudflare Pages edge headers.
# Worker-served /api/* responses set their own headers in worker-additions/worker.js
# (see SECURITY_HEADERS const). Keep the two surfaces in lockstep.

/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), interest-cohort=()
  X-XSS-Protection: 0
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: cross-origin

# Embeddable widgets are explicitly designed to be iframed by other sites.
# Strip X-Frame-Options on /widgets/* only and use frame-ancestors *.
/widgets/*
  X-Frame-Options: ALLOWALL
  Content-Security-Policy: frame-ancestors *
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
